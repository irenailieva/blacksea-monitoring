DATABASE_URL=postgresql://postgres:1401@db:5432/blacksea_monitor

# Режим по подразбиране (override-ва се от CLI аргументи)
ETL_MODE=mock

# Папка за изходни файлове (можеш да промениш)
ETL_OUT_DIR=out

# Пример: бъдещи ключове (остави празни засега)
# COPERNICUS_CLIENT_ID=
# COPERNICUS_CLIENT_SECRET=